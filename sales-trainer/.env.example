# ──────────────────────────────────────────────────────────────────────────────
# Supabase — obter em: https://supabase.com/dashboard/project/<id>/settings/api
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Apenas servidor — NUNCA prefixar com NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ──────────────────────────────────────────────────────────────────────────────
# OpenRouter — obter em: https://openrouter.ai/keys
# NUNCA expor no browser — apenas variáveis sem NEXT_PUBLIC_
# ──────────────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...

# Modelos — trocar aqui sem mexer em código
OPENROUTER_CHAT_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_EVAL_MODEL=openai/gpt-4o-mini
OPENROUTER_SUGGEST_MODEL=openai/gpt-4o-mini

# ──────────────────────────────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────────
# n8n — para webhooks de avaliação pós-sessão
# ──────────────────────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://<seu-n8n>.app/webhook/<id>
N8N_WEBHOOK_SECRET=<segredo-para-validar-callbacks>
